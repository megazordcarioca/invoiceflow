# Supabase — copy to .env.local
# For local dev: run `npx supabase start` and copy keys from output
# For production: use values from Settings > API at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Resend (email reminders) — get API key from https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=InvoiceFlow <onboarding@resend.dev>
